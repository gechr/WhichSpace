{
  "sourceLanguage" : "en",
  "strings" : {
    "Applies a badge character to the current Space (\"#\" shows the Space number). An empty badge resets it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يطبق حرف شارة على المساحة الحالية (\"#\" يعرض رقم المساحة). الشارة الفارغة تعيد تعيينها."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прилага символ на значка към текущото Пространство (\"#\" показва номера на Пространството). Празна значка я нулира."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplica un caràcter de distintiu a l'Espai actual (\"#\" mostra el número de l'Espai). Un distintiu buit el restableix."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Použije znak odznaku na aktuální Space (\"#\" zobrazí číslo Space). Prázdný odznak jej obnoví."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anvender et mærketegn på det aktuelle Space (\"#\" viser Space-nummeret). Et tomt mærke nulstiller det."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wendet ein Abzeichen-Zeichen auf den aktuellen Space an (\"#\" zeigt die Space-Nummer). Ein leeres Abzeichen setzt es zurück."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εφαρμόζει χαρακτήρα σήματος στον τρέχοντα Χώρο (το \"#\" εμφανίζει τον αριθμό του Χώρου). Ένα κενό σήμα το επαναφέρει."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies a badge character to the current Space (\"#\" shows the Space number). An empty badge resets it."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies a badge character to the current Space (\"#\" shows the Space number). An empty badge resets it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplica un carácter de distintivo al Espacio actual (\"#\" muestra el número del Espacio). Un distintivo vacío lo restablece."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نویسه‌ای به‌عنوان نشان به فضای فعلی اعمال می‌کند (\"#\" شماره فضا را نشان می‌دهد). نشان خالی آن را بازنشانی می‌کند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käyttää merkkikirjainta nykyiseen Spaceen (\"#\" näyttää Spacen numeron). Tyhjä merkki palauttaa sen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applique un caractère de badge à l'Espace actuel (\"#\" affiche le numéro de l'Espace). Un badge vide le réinitialise."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מחיל תו תג על המרחב הנוכחי (\"#\" מציג את מספר המרחב). תג ריק מאפס אותו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वर्तमान स्पेस पर बैज वर्ण लागू करता है (\"#\" स्पेस नंबर दिखाता है)। खाली बैज इसे रीसेट करता है।"
