    "alert_custom_sounds_detail" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لإضافة أصوات مخصصة، انسخ ملفات الصوت إلى مجلد ~/Library/Sounds. ستظهر ضمن قسم \"المستخدم\" في قائمة الصوت."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За да добавите персонализирани звуци, копирайте звукови файлове в папката ~/Library/Sounds. Те ще се появят в раздел \"Потребителски\" на менюто Звук."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per afegir sons personalitzats, copia els fitxers de so a la carpeta ~/Library/Sounds. Apareixeran a la secció \"Usuari\" del menú So."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcete-li přidat vlastní zvuky, zkopírujte zvukové soubory do složky ~/Library/Sounds. Zobrazí se v sekci \"Uživatelské\" v nabídce Zvuk."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For at tilføje tilpassede lyde skal du kopiere lydfiler til mappen ~/Library/Sounds. De vises under sektionen \"Bruger\" i menuen Lyd."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um eigene Töne hinzuzufügen, kopiere Audiodateien in den Ordner ~/Library/Sounds. Sie erscheinen im Bereich \"Benutzer\" des Menüs \"Ton\"."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Για να προσθέσετε προσαρμοσμένους ήχους, αντιγράψτε αρχεία ήχου στον φάκελο ~/Library/Sounds. Θα εμφανιστούν στην ενότητα \"Χρήστης\" του μενού Ήχος."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To add custom sounds, copy sound files into the ~/Library/Sounds folder. They will appear under the \"User\" section of the Sound menu."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To add custom sounds, copy sound files into the ~/Library/Sounds folder. They will appear under the \"User\" section of the Sound menu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para añadir sonidos personalizados, copie los archivos de sonido en la carpeta ~/Library/Sounds. Aparecerán en la sección \"Usuario\" del menú Sonido."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای افزودن صداهای سفارشی، فایل‌های صوتی را در پوشه ~/Library/Sounds کپی کنید. آنها در بخش \"کاربر\" منوی صدا نمایش داده می‌شوند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lisää mukautettuja ääniä kopioimalla äänitiedostot kansioon ~/Library/Sounds. Ne näkyvät Ääni-valikon \"Käyttäjä\"-osiossa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour ajouter des sons personnalisés, copiez les fichiers audio dans le dossier ~/Library/Sounds. Ils apparaîtront dans la section \"Utilisateur\" du menu Son."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כדי להוסיף צלילים מותאמים אישית, העתק קובצי צליל אל התיקייה ~/Library/Sounds. הם יופיעו תחת המקטע \"משתמש\" בתפריט הצליל."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कस्टम ध्वनियाँ जोड़ने के लिए, ध्वनि फ़ाइलों को ~/Library/Sounds फ़ोल्डर में कॉपी करें। वे ध्वनि मेनू के \"उपयोगकर्ता\" खंड में दिखाई देंगी।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egyéni hangok hozzáadásához másolja a hangfájlokat a ~/Library/Sounds mappába. A Hang menü \"Felhasználó\" szakaszában jelennek meg."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menambahkan suara khusus, salin file suara ke folder ~/Library/Sounds. Suara tersebut akan muncul di bagian \"Pengguna\" pada menu Suara."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per aggiungere suoni personalizzati, copia i file audio nella cartella ~/Library/Sounds. Appariranno nella sezione \"Utente\" del menu Suono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カスタムサウンドを追加するには、サウンドファイルを~/Library/Soundsフォルダにコピーしてください。サウンドメニューの「ユーザー」セクションに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용자 지정 사운드를 추가하려면 사운드 파일을 ~/Library/Sounds 폴더에 복사하세요. 사운드 메뉴의 \"사용자\" 섹션에 나타납니다."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За да додадете прилагодени звуци, копирајте ги звучните датотеки во папката ~/Library/Sounds. Тие ќе се појават во делот \"Кориснички\" од менито Звук."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menambah bunyi tersuai, salin fail bunyi ke dalam folder ~/Library/Sounds. Bunyi itu akan muncul di bahagian \"Pengguna\" dalam menu Bunyi."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For å legge til tilpassede lyder, kopier lydfiler til mappen ~/Library/Sounds. De vises under \"Bruker\"-delen i menyen Lyd."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om aangepaste geluiden toe te voegen, kopieer je geluidsbestanden naar de map ~/Library/Sounds. Ze verschijnen onder het gedeelte \"Gebruiker\" in het menu Geluid."
          }
        },
        "nn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For å leggje til tilpassa lydar, kopier lydfiler til mappa ~/Library/Sounds. Dei blir viste under \"Brukar\"-delen i menyen Lyd."
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنی مرضی دیاں آوازاں شامل کرن لئی، آڈیو فائلاں نوں ~/Library/Sounds فولڈر وچ کاپی کرو۔ اوہ آواز مینیو دے \"صارف\" حصے وچ نظر آون گیاں۔"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aby dodać niestandardowe dźwięki, skopiuj pliki dźwiękowe do folderu ~/Library/Sounds. Pojawią się w sekcji \"Użytkownik\" menu Dźwięk."
          }
        },
        "ps" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "د ځانګړو غږونو د اضافه کولو لپاره، د غږ فایلونه ~/Library/Sounds فولډر ته کاپي کړئ. دوی به د غږ مینو په \"کاروونکی\" برخه کې ښکاره شي."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para adicionar sons personalizados, copie os ficheiros de som para a pasta ~/Library/Sounds. Aparecerão na secção \"Utilizador\" do menu Som."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para adicionar sons personalizados, copie os arquivos de som para a pasta ~/Library/Sounds. Eles aparecerão na seção \"Usuário\" do menu Som."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pentru a adăuga sunete personalizate, copiați fișierele de sunet în dosarul ~/Library/Sounds. Vor apărea în secțiunea \"Utilizator\" din meniul Sunet."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы добавить собственные звуки, скопируйте звуковые файлы в папку ~/Library/Sounds. Они появятся в разделе \"Пользовательские\" меню \"Звук\"."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak chcete pridať vlastné zvuky, skopírujte zvukové súbory do priečinka ~/Library/Sounds. Zobrazia sa v sekcii \"Používateľské\" v menu Zvuk."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Da biste dodali prilagođene zvuke, kopirajte zvučne datoteke u fasciklu ~/Library/Sounds. Pojaviće se u odeljku \"Korisnik\" menija Zvuk."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "För att lägga till anpassade ljud, kopiera ljudfiler till mappen ~/Library/Sounds. De visas under avsnittet \"Användare\" i menyn Ljud."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากต้องการเพิ่มเสียงกำหนดเอง ให้คัดลอกไฟล์เสียงไปยังโฟลเดอร์ ~/Library/Sounds ไฟล์เหล่านั้นจะปรากฏในส่วน \"ผู้ใช้\" ของเมนูเสียง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Özel sesler eklemek için ses dosyalarını ~/Library/Sounds klasörüne kopyalayın. Ses menüsünün \"Kullanıcı\" bölümünde görünürler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щоб додати власні звуки, скопіюйте звукові файли до папки ~/Library/Sounds. Вони з'являться в розділі \"Користувацькі\" меню \"Звук\"."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حسب ضرورت آوازیں شامل کرنے کے لیے، آواز کی فائلیں ~/Library/Sounds فولڈر میں کاپی کریں۔ وہ آواز مینیو کے \"صارف\" سیکشن میں ظاہر ہوں گی۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Để thêm âm thanh tùy chỉnh, hãy sao chép các tệp âm thanh vào thư mục ~/Library/Sounds. Chúng sẽ xuất hiện trong mục \"Người dùng\" của menu Âm thanh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要添加自定义声音，请将声音文件拷贝到~/Library/Sounds文件夹。它们将显示在声音菜单的“用户”部分。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要加入自訂聲音，請將聲音檔案拷貝到~/Library/Sounds檔案夾。它們會顯示在聲音選單的「使用者」部分。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要加入自訂聲音，請將聲音檔案拷貝到~/Library/Sounds檔案夾。它們會顯示在聲音選單的「使用者」部分。"
          }
        }
      }
    },
