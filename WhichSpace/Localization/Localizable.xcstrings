    "Switches to a Space on the current display, optionally applying a label and badge." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "للتبديل إلى مساحة على الشاشة الحالية، مع إمكانية تطبيق تسمية وشارة."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Превключва към Пространство на текущия дисплей, по избор прилага етикет и значка."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Canvia a un Espai de la pantalla actual i, opcionalment, hi aplica una etiqueta i un distintiu."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přepne na Space na aktuálním displeji a volitelně použije štítek a odznak."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skifter til et Space på den aktuelle skærm og anvender eventuelt en etiket og et mærke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wechselt zu einem Space auf dem aktuellen Display und wendet optional ein Etikett und ein Abzeichen an."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μεταβαίνει σε έναν Χώρο στην τρέχουσα οθόνη, εφαρμόζοντας προαιρετικά ετικέτα και σήμα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switches to a Space on the current display, optionally applying a label and badge."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switches to a Space on the current display, optionally applying a label and badge."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia a un Espacio de la pantalla actual y, opcionalmente, aplica una etiqueta y un distintivo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "به فضایی در نمایشگر فعلی می‌رود و در صورت تمایل برچسب و نشان اعمال می‌کند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaihtaa Spaceen nykyisellä näytöllä ja käyttää halutessa tunnistetta ja merkkiä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe à un Espace de l'écran actuel, en appliquant éventuellement une étiquette et un badge."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עובר למרחב בצג הנוכחי, ומחיל תווית ותג אם נבחרו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वर्तमान डिस्प्ले पर किसी स्पेस पर स्विच करता है, वैकल्पिक रूप से लेबल और बैज लागू करता है।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Átvált egy Space-re az aktuális kijelzőn, és igény szerint címkét és jelvényt alkalmaz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beralih ke Space di layar saat ini, dengan opsi menerapkan label dan lencana."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passa a uno Spazio dello schermo attuale, applicando facoltativamente un'etichetta e un badge."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のディスプレイのスペースに切り替え、必要に応じてラベルとバッジを適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 디스플레이의 스페이스로 전환하며, 선택적으로 레이블과 배지를 적용합니다."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Преминува на Простор на тековниот екран, по избор применува етикета и значка."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bertukar ke Ruang pada paparan semasa, dengan pilihan menggunakan label dan lencana."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bytter til et Space på gjeldende skjerm og bruker eventuelt en etikett og et merke."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wisselt naar een Space op het huidige beeldscherm en past optioneel een label en badge toe."
